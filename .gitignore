# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# macOS system files
.DS_Store

# Local data files and directories
data/
*.csv
*.json
*.parquet
*.sqlite
*.db

# Tool caches
.worktrees/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Coverage output
.coverage
coverage.xml
htmlcov/

# Model weights / build output (never committed)
*.onnx
*.safetensors
*.bin
*.pt

# OAR scheduler stdout/stderr files written into the launching
# directory on the Grid'5000 frontend. The compute-node wrapper
# checks `git status --porcelain` and rejects a dirty tree, so
# these redirected files must not appear as untracked entries.
OAR.*.stdout
OAR.*.stderr
