# Files included in the source distribution.
# The wheel installs package code, py.typed, and metadata only; the
# docs/ tree lives in the project tree and ships in the sdist for
# offline reference but is not installed.

include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include SECURITY.md
include pyproject.toml
include .python-version

recursive-include docs *.md
recursive-include scripts *.py
recursive-include scripts *.sh
recursive-include tests *.py

# Exclude caches, build output, data, credentials, model weights, and
# the local-only coding-agent handoff guide.
prune .local-docs
prune .mypy_cache
prune .pytest_cache
prune .ruff_cache
prune build
prune dist
exclude .coverage
exclude coverage.xml
recursive-exclude * __pycache__
recursive-exclude * *.pyc
recursive-exclude data *
recursive-exclude * *.parquet
recursive-exclude * *.onnx
recursive-exclude * *.safetensors
recursive-exclude * *.bin
global-exclude .DS_Store

# Vendored Natural Earth outline (single-country subset) ships
# inside the package so publication does not require network access.
include src/osm_polygon_sentence_relevance/output/_vendor/natural_earth/afghanistan_outline.geojson
include src/osm_polygon_sentence_relevance/output/_vendor/natural_earth/README.md
